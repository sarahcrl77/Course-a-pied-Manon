border:none;
border-radius:8px;
cursor:pointer;
}

.start{
background:#27ae60;
color:white;
}

.discover{
background:#2980b9;
color:white;
}

.promo{
background:#e74c3c;
color:white;
font-weight:bold;
}

footer{
margin-top:60px;
padding:20px;
color:#777;
}

</style>

