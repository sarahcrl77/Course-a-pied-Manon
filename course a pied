<!DOCTYPE html>
<html lang="fr">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Running App</title>

<style>

body{
font-family: Arial, sans-serif;
margin:0;
background:#f4f4f4;
color:#333;
text-align:center;
}

header{
background:#111;
color:white;
padding:60px 20px;
}

h1{
font-size:38px;
margin-bottom:10px;
}

.subtitle{
font-size:20px;
}

.container{
max-width:900px;
margin:auto;
padding:40px 20px;
}

.promise{
font-size:24px;
font-weight:bold;
margin-bottom:30px;
}

.benefits{
display:flex;
flex-direction:column;
gap:15px;
margin-bottom:40px;
}

.benefit{
background:white;
padding:15px;
border-radius:8px;
box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.buttons{
display:flex;
justify-content:center;
gap:15px;
flex-wrap:wrap;
}

button{
padding:15px 25px;
